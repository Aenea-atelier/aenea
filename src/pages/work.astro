---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

const title = "Selected Work — Brand Identity & Web Design Projects | Aenea";
const description = "Selected work from Aenea — brand identities, websites, and visual systems for architecture studios, hotels, jewellery, and design-led brands.";

const projects = [
  { title: 'Atelier B', cat: 'Brand Identity', slug: 'atelier-b', img: '/atelier-b.jpg', span: 'c7', ar: 'a-lg' },
  { title: 'Golden Hour', cat: 'Logo Design', slug: 'golden-hour', img: '/golden-hour.jpg', span: 'c5', ar: 'a-tall' },
  { title: 'Ceramo', cat: 'Logo Design', slug: 'ceramo', img: '/ceramo.jpg', span: 'c5', ar: 'a-tall' },
  { title: 'Conture', cat: 'Brand Identity', slug: 'conture', img: '/conture.jpg', span: 'c7', ar: 'a-lg' },
  { title: 'Éclat', cat: 'Web Design', slug: 'eclat', img: '/eclat.jpg', span: 'c6', ar: 'a-med' },
  { title: 'Jewellery Brand', cat: 'Social Visuals', slug: 'jewellery', img: '/jewellery.jpg', span: 'c6', ar: 'a-med' },
  { title: 'AI Brand Imagery', cat: 'Art Direction', slug: 'ai-imagery', img: '/ai-imagery.jpg', span: 'c12', ar: 'a-wide' },
];
---

<Layout title={title} description={description}>
  <Navbar current="work" />

  <main>
    <section class="proj-intro wrap">
      <span class="eyebrow proj-cat">Selected Work</span>
      <h1 class="proj-title">An index of recent projects.</h1>
      <p class="proj-lead">A curated selection of brand identities, digital experiences, and visual systems — built for design-led businesses across architecture, hospitality, and beyond.</p>
    </section>

    <section class="wrap" style="padding-bottom:clamp(60px,10vh,120px)">
      <div class="work-grid">
        {projects.map((p) => (
          <article class={`plate ${p.span} ${p.ar}`}>
            <a class="plate-link" href={`/work/${p.slug}`}>
              <div class="plate-img"><img src={p.img} loading="lazy" alt={`${p.title} — ${p.cat} by Aenea`} /></div>
              <div class="plate-meta">
                <div><span class="plate-title">{p.title}</span><span class="plate-cat">{p.cat}</span></div>
                <span class="plate-view" aria-hidden="true">↗</span>
              </div>
            </a>
          </article>
        ))}
      </div>
    </section>
  </main>

  <Footer />
</Layout>