---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';

export async function getStaticPaths() {
  return [
    { params: { slug: 'atelier-b' } },
    { params: { slug: 'golden-hour' } },
    { params: { slug: 'jewellery' } },
    { params: { slug: 'ai-imagery' } },
    { params: { slug: 'ceramo' } },
    { params: { slug: 'conture' } },
    { params: { slug: 'eclat' } },
  ];
}

const { slug } = Astro.params;
---

<Layout title={`${slug} — Aenea`}>
  <Navbar />
  
  <section class="px-6 md:px-12 py-16 md:py-24">
    <h1 class="text-4xl md:text-5xl font-medium text-gray-900 mb-6">{slug.charAt(0).toUpperCase() + slug.slice(1).replace('-', ' ')}</h1>
    <p class="text-lg text-gray-600 mb-12">Detailed project case study coming soon.</p>
  </section>

  <Footer />
</Layout>