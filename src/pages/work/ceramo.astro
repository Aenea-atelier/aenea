---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import GalleryLightbox from '../../components/GalleryLightbox.astro';
---

<Layout title="Ceramo Studio Logo Design — Aenea">
  <Navbar />
  
  <section class="px-6 md:px-12 py-16 md:py-24">
    <div class="mb-8">
      <h1 class="text-4xl md:text-5xl font-medium text-gray-900 mb-2">Ceramo Studio Logo Design</h1>
      <div class="flex gap-6 text-xs md:text-sm text-gray-600">
        <span><strong>Service:</strong> Logo Design</span>
        <span><strong>Year:</strong> 2025</span>
      </div>
    </div>

    {/* Hero Image */}
    <div class="mb-12">
      <button data-lightbox class="w-full overflow-hidden rounded-lg bg-gray-100 cursor-pointer border-none p-0 h-80">
        <img src="/ceramo-hero.jpg" alt="Ceramo Studio Logo Design" class="w-full h-full object-cover hover:scale-105 transition-transform duration-300" style="object-position: center 50%;" />
      </button>
    </div>

    {/* Gallery - 4 boxes in one row */}
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-4 mb-12">
      <button data-lightbox class="overflow-hidden rounded-lg bg-gray-100 cursor-pointer border-none p-0 aspect-square">
        <img src="/ceramo-1.jpg" alt="Ceramo - 1" class="w-full h-full object-cover hover:scale-105 transition-transform duration-300" />
      </button>
      
      <button data-lightbox class="overflow-hidden rounded-lg bg-gray-100 cursor-pointer border-none p-0 aspect-square">
        <img src="/ceramo-2.jpg" alt="Ceramo - 2" class="w-full h-full object-cover hover:scale-105 transition-transform duration-300" />
      </button>
      
      <button data-lightbox class="overflow-hidden rounded-lg bg-gray-100 cursor-pointer border-none p-0 aspect-square">
        <img src="/ceramo-3.jpg" alt="Ceramo - 3" class="w-full h-full object-cover hover:scale-105 transition-transform duration-300" />
      </button>
      
      <button data-lightbox class="overflow-hidden rounded-lg bg-gray-100 cursor-pointer border-none p-0 aspect-square">
        <img src="/ceramo-4.jpg" alt="Ceramo - 4" class="w-full h-full object-cover hover:scale-105 transition-transform duration-300" />
      </button>
    </div>

    {/* Copy Link */}
    <div class="mb-12">
      <button id="copy-link-btn" class="flex items-center gap-2 px-4 py-2 border border-gray-900 rounded-full text-sm hover:bg-gray-50 transition-colors cursor-pointer">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.658 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" />
        </svg>
        <span>Copy Link</span>
      </button>
    </div>

    {/* Description */}
    <div>
      <p class="text-sm md:text-base text-gray-700 mb-4 leading-relaxed">
        The logo design for Ceramo Studio is rooted in material honesty and quiet craftsmanship. Inspired by the tactile nature of clay and the discipline of ceramic making, the mark balances softness and structure - reflecting the dialogue between hand and form.
      </p>
      
      <p class="text-sm md:text-base text-gray-700 mb-4 leading-relaxed">
        Construction is minimal and deliberate. Subtle curves echo the organic imperfections of ceramics, while the overall geometry stays controlled and precise. The contrast creates a visual language that feels grounded, refined, and unhurried.
      </p>
      
      <p class="text-sm md:text-base text-gray-700 mb-4 leading-relaxed">
        Typography is understated. It allows texture and proportion to carry the identity - no excess, only intention. The logo holds across physical and digital applications equally: studio signage, packaging, stamps, documentation.
      </p>
      
      <p class="text-sm md:text-base text-gray-700 leading-relaxed">
        It doesn't seek attention. It earns it - through balance, restraint, and material awareness. Designed to be felt as much as it is seen.
      </p>
    </div>
  </section>

  <Footer />
  <GalleryLightbox />
</Layout>

<script>
  document.getElementById('copy-link-btn').addEventListener('click', () => {
    navigator.clipboard.writeText(window.location.href);
    const btn = document.getElementById('copy-link-btn');
    const originalHTML = btn.innerHTML;
    btn.innerHTML = '<svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17z"/></svg><span>Copied!</span>';
    setTimeout(() => {
      btn.innerHTML = originalHTML;
    }, 2000);
  });
</script>