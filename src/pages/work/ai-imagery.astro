---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import GalleryLightbox from '../../components/GalleryLightbox.astro';

const title = "AI Brand Imagery — Art Direction & Visual Exploration | Aenea";
const description = "AI-generated brand imagery by Aenea, approached as a creative tool — exploring atmosphere, material, and mood in early brand development. Technology in service of craft.";
---

<Layout title={title} description={description}>
  <Navbar current="work" />

  <main>
    <section class="proj-intro wrap">
      <a href="/work" class="back-link"><span aria-hidden="true">←</span> Selected Work</a>
      <span class="eyebrow proj-cat">Art Direction</span>
      <h1 class="proj-title">AI Brand Imagery</h1>
      <p class="proj-lead">AI-generated imagery approached as a creative tool, not a shortcut — used in early brand development to explore atmosphere, material, and mood before committing to a visual direction.</p>
      <div class="proj-meta">
        <div><div class="meta-k">Service</div><div class="meta-v">Art Direction</div></div>
        <div><div class="meta-k">Sector</div><div class="meta-v">Brand Exploration</div></div>
        <div><div class="meta-k">Year</div><div class="meta-v">2025</div></div>
        <div><div class="meta-k">Deliverables</div><div class="meta-v">Concept imagery, Art direction, Mood</div></div>
      </div>
    </section>

    <figure class="bleed" data-lightbox>
      <img src="/ai-imagery-hero.jpg" alt="AI brand imagery — concept art direction exploring form, texture, and mood, by Aenea" />
    </figure>

    <section class="case wrap">
      <div class="case-label"><span class="idx">01</span><span class="eyebrow">Overview</span></div>
      <div class="case-body">
        <p>AI-generated imagery approached as a creative tool, not a shortcut. Used in the early stages of brand development, it lets us explore atmosphere, material, and mood before committing to a visual direction — a space for experimentation, testing what a brand could feel like before defining what it will look like.</p>
      </div>
    </section>

    <section class="wrap">
      <div class="pair">
        <figure class="ph s7 r43" data-lightbox><img src="/ai-imagery-1.jpg" alt="AI brand imagery exploring material and texture, by Aenea" /></figure>
        <figure class="ph s5 r45" data-lightbox><img src="/ai-imagery-2.jpg" alt="AI-generated concept image exploring mood and atmosphere" /></figure>
      </div>
    </section>

    <section class="case wrap">
      <div class="case-label"><span class="idx">02</span><span class="eyebrow">The Approach</span></div>
      <div class="case-body">
        <p>Each image begins with a brief and ends with intention. Prompting, selection, and refinement shape visuals that feel considered rather than generated. The result is imagery that supports brand storytelling and expands the visual world of a project — plausible, elevated, and on-brand.</p>
        <p>Technology in service of craft. Not the other way around.</p>
      </div>
    </section>

    <section class="wrap">
      <div class="pair">
        <figure class="ph s5 r45" data-lightbox><img src="/ai-imagery-3.jpg" alt="AI brand imagery — abstract texture study" /></figure>
        <figure class="ph s7 r43" data-lightbox><img src="/ai-imagery-4.jpg" alt="AI brand imagery — atmospheric concept frame" /></figure>
      </div>
    </section>

    <section class="case wrap">
      <div class="case-label"><span class="idx">03</span><span class="eyebrow">Outcome</span></div>
      <div class="case-body">
        <p>Imagery that supports brand storytelling and expands the visual world of a project — plausible, elevated, and unmistakably on-brand, while the human direction stays firmly in control.</p>
      </div>
    </section>

    <section class="next wrap">
      <a href="/work/atelier-b" class="next-link">
        <span class="next-k">Next project</span>
        <span class="next-title">Atelier B <span class="arr" aria-hidden="true">↗</span></span>
        <span class="next-cat">Brand Identity</span>
      </a>
    </section>
  </main>

  <Footer />
  <GalleryLightbox />
</Layout>