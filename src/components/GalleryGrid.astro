---
---
<section class="section wrap" id="work" aria-label="Selected work">
  <div class="section-head">
    <div>
      <span class="eyebrow">Selected Work</span>
      <h2 style="margin-top:14px">An index of recent projects.</h2>
    </div>
    <a href="/work" class="link-arrow"><span>See all</span> <span class="arr" aria-hidden="true">↗</span></a>
  </div>

  <div class="work-grid">
    <article class="plate c7 a-lg">
      <a class="plate-link" href="/work/atelier-b">
        <div class="plate-img"><img src="/atelier-b.jpg" loading="lazy" alt="Brand identity for Atelier B, a contemporary architecture studio" /></div>
        <div class="plate-meta">
          <div><span class="plate-title">Atelier B</span><span class="plate-cat">Brand Identity</span></div>
          <span class="plate-view" aria-hidden="true">↗</span>
        </div>
      </a>
    </article>

    <article class="plate c5 a-tall">
      <a class="plate-link" href="/work/golden-hour">
        <div class="plate-img"><img src="/golden-hour.jpg" loading="lazy" alt="Logo design for Golden Hour, a modern European dining concept" /></div>
        <div class="plate-meta">
          <div><span class="plate-title">Golden Hour</span><span class="plate-cat">Logo Design</span></div>
          <span class="plate-view" aria-hidden="true">↗</span>
        </div>
      </a>
    </article>

    <article class="plate c5 a-tall">
      <a class="plate-link" href="/work/ceramo">
        <div class="plate-img"><img src="/ceramo.jpg" loading="lazy" alt="Logo design for Ceramo, a ceramic studio" /></div>
        <div class="plate-meta">
          <div><span class="plate-title">Ceramo</span><span class="plate-cat">Logo Design</span></div>
          <span class="plate-view" aria-hidden="true">↗</span>
        </div>
      </a>
    </article>

    <article class="plate c7 a-lg">
      <a class="plate-link" href="/work/conture">
        <div class="plate-img"><img src="/conture.jpg" loading="lazy" alt="Brand identity for Conture, a modern beauty salon" /></div>
        <div class="plate-meta">
          <div><span class="plate-title">Conture</span><span class="plate-cat">Brand Identity</span></div>
          <span class="plate-view" aria-hidden="true">↗</span>
        </div>
      </a>
    </article>

    <article class="plate c6 a-med">
      <a class="plate-link" href="/work/eclat">
        <div class="plate-img"><img src="/eclat.jpg" loading="lazy" alt="Web design for Éclat, a high-end jewellery boutique" /></div>
        <div class="plate-meta">
          <div><span class="plate-title">Éclat</span><span class="plate-cat">Web Design</span></div>
          <span class="plate-view" aria-hidden="true">↗</span>
        </div>
      </a>
    </article>

    <article class="plate c6 a-med">
      <a class="plate-link" href="/work/jewellery">
        <div class="plate-img"><img src="/jewellery.jpg" loading="lazy" alt="Social media visual system for a fine jewellery brand" /></div>
        <div class="plate-meta">
          <div><span class="plate-title">Jewellery Brand</span><span class="plate-cat">Social Visuals</span></div>
          <span class="plate-view" aria-hidden="true">↗</span>
        </div>
      </a>
    </article>

    <article class="plate c12 a-wide">
      <a class="plate-link" href="/work/ai-imagery">
        <div class="plate-img"><img src="/ai-imagery.jpg" loading="lazy" alt="AI-assisted brand imagery exploring form, texture, and mood" /></div>
        <div class="plate-meta">
          <div><span class="plate-title">AI Brand Imagery</span><span class="plate-cat">Art Direction</span></div>
          <span class="plate-view" aria-hidden="true">↗</span>
        </div>
      </a>
    </article>
  </div>
</section>