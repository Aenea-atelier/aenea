---
const projects = [
  { title: 'Atelier B Brand Design', slug: 'atelier-b', desc: 'Identity design for a contemporary architecture studio.', img: '/atelier-b.jpg' },
  { title: 'Golden Hour Logo Design', slug: 'golden-hour', desc: 'Logo design for a modern European dining concept.', img: '/golden-hour.jpg' },
  { title: 'Ceramo Studio Logo Design', slug: 'ceramo', desc: 'Logo design for a ceramic studio.', img: '/ceramo.jpg' },
  { title: 'Conture Salon Brand Design', slug: 'conture', desc: 'Brand identity for a modern beauty salon.', img: '/conture.jpg' },
  { title: 'Éclat Studio Web Design', slug: 'eclat', desc: 'Web design for a high-end jewellery boutique.', img: '/eclat.jpg' },
  { title: 'Jewellery Brand SM Visuals', slug: 'jewellery', desc: 'Social media visual system for a fine jewellery brand.', img: '/jewellery.jpg' },
  { title: 'AI-Generated Brand Imagery', slug: 'ai-imagery', desc: 'AI-assisted brand imagery exploring form, texture, and mood.', img: '/ai-imagery.jpg' },
];
---
<section class="px-6 md:px-12 mb-16 md:mb-24">
  <div class="flex justify-between items-baseline mb-8">
    <h2 class="text-3xl md:text-4xl font-medium text-gray-900">Gallery Of My Work</h2>
    <a href="/work" class="text-sm text-gray-500 hover:text-gray-900 transition-colors">See All</a>
  </div>
  
  <div class="grid grid-cols-5 gap-6">
    {/* Velika slika lijevo */}
    <div class="group col-span-2 row-span-2 flex flex-col">
      <button data-lightbox class="overflow-hidden rounded-xl mb-3 bg-gray-100 aspect-square cursor-pointer flex-1 flex items-center justify-center border-0 p-0">
        <img src={projects[0].img} alt={projects[0].title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" />
      </button>
      <h3 class="text-sm font-medium text-gray-900 mb-1">{projects[0].title}</h3>
      <p class="text-xs text-gray-400 leading-relaxed mb-4">{projects[0].desc}</p>
      <a href={`/work/${projects[0].slug}`} class="text-xs font-medium text-gray-900 hover:text-gray-600 transition-colors">
        View Full Project →
      </a>
    </div>

    {/* 6 manjih slika desno */}
    {projects.slice(1).map(p => (
      <div class="group col-span-1 flex flex-col">
        <button data-lightbox class="overflow-hidden rounded-xl mb-3 bg-gray-100 aspect-square cursor-pointer flex-1 flex items-center justify-center border-0 p-0">
          <img src={p.img} alt={p.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" />
        </button>
        <h3 class="text-sm font-medium text-gray-900 mb-1">{p.title}</h3>
        <p class="text-xs text-gray-400 leading-relaxed mb-4">{p.desc}</p>
        <a href={`/work/${p.slug}`} class="text-xs font-medium text-gray-900 hover:text-gray-600 transition-colors">
          View Full Project →
        </a>
      </div>
    ))}
  </div>
</section>