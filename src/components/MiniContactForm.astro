---
---
<section class="contact-hero wrap" id="contact" aria-label="Contact">
  <span class="eyebrow">Contact</span>
  <h2 class="big-talk">Let&rsquo;s talk.</h2>
  <p class="contact-sub">Tell me about your project. I&rsquo;ll reply within 48 hours.</p>
  <a class="scroll-cue" href="#contact-form">Start below <span class="dn" aria-hidden="true">↓</span></a>
</section>

<section class="section wrap" id="contact-form" aria-label="Send a message">
  <div class="contact-grid">
    <form class="contact-form" name="contact" method="POST" data-netlify="true">
      <input type="hidden" name="form-name" value="contact" />
      <div class="field-row">
        <div class="field"><label for="name">Name</label><input id="name" name="name" type="text" placeholder="Your name" required /></div>
        <div class="field"><label for="email">Email</label><input id="email" name="email" type="email" placeholder="you@studio.com" required /></div>
      </div>
      <div class="field"><label for="msg">Message</label><textarea id="msg" name="message" placeholder="A few lines about what you&rsquo;re building"></textarea></div>
      <button class="btn submit" type="submit">Send message <span aria-hidden="true">↗</span></button>
    </form>

    <aside class="contact-aside">
      <p class="aside-intro">Based in Norway, working with clients internationally. Taking on a small number of projects for 2026 — even a short note is enough to start.</p>
      <div class="aside-block">
        <div class="aside-k">Telephone</div>
        <div class="aside-v"><a href="tel:+4794098533">+47 940 98 533</a></div>
      </div>
      <div class="aside-block">
        <div class="aside-k">Instagram</div>
        <div class="aside-v"><a href="https://www.instagram.com/aenea_solutions/">@aenea_solutions</a></div>
      </div>
    </aside>
  </div>
</section>