---
const { current = "" } = Astro.props;
---
<header id="site-header">
  <div class="wrap nav">
    <a href="/" class="brand-lockup" aria-label="Aenea — home">
      <img class="brand-logo" src="/logo-aenea.png" alt="" />
      <span class="brand-divider" aria-hidden="true"></span>
      <span class="brand-desc">Branding &amp; UX/UI Studio</span>
    </a>
    <div class="nav-right">
      <nav class="nav-links" aria-label="Primary">
        <a href="/" class:list={[{ current: current === "home" }]}>Home</a>
        <a href="/studio" class:list={[{ current: current === "studio" }]}>Studio</a>
        <a href="/#services">Services</a>
        <a href="/work" class:list={[{ current: current === "work" }]}>Work</a>
      </nav>
      <span class="status" aria-label="Studio availability"><span class="status-dot" aria-hidden="true"></span>Open for 2026</span>
      <a href="/#contact" class="say-hi">Say Hi</a>
    </div>
    <button class="menu-btn" id="menu-open" aria-label="Open menu">Menu</button>
  </div>
</header>

<div class="overlay" id="overlay" aria-hidden="true">
  <button class="overlay-close" id="menu-close" aria-label="Close menu">Close</button>
  <a href="/">Home</a>
  <a href="/studio">Studio</a>
  <a href="/#services">Services</a>
  <a href="https://enas-newsletter-309b7c.beehiiv.com">Letters from me</a>
  <a href="/work">Work</a>
  <a href="/#contact">Say Hi</a>
</div>

<script is:inline>
  const header = document.getElementById('site-header');
  const onScroll = () => header.classList.toggle('scrolled', window.scrollY > 8);
  onScroll(); window.addEventListener('scroll', onScroll, { passive: true });
  const overlay = document.getElementById('overlay');
  const setMenu = (s) => { overlay.classList.toggle('open', s); document.body.style.overflow = s ? 'hidden' : ''; };
  document.getElementById('menu-open')?.addEventListener('click', () => setMenu(true));
  document.getElementById('menu-close')?.addEventListener('click', () => setMenu(false));
  overlay.querySelectorAll('a').forEach(a => a.addEventListener('click', () => setMenu(false)));
</script>